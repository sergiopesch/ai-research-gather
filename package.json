{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "concurrently -k \"tsx watch server/index.ts\" \"vite\"",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "check": "npm run lint && npm run typecheck:server && npm run build",
    "eval:scripts": "tsx evals/run-script-eval.ts",
    "lint": "eslint .",
    "preview": "npm run build && tsx server/index.ts",
    "start": "tsx server/index.ts",
    "healthcheck": "node -e \"fetch('http://127.0.0.1:' + (process.env.PORT || 3001) + '/api/health').then(async r=>{const t=await r.text();if(!r.ok)throw new Error('Healthcheck failed: HTTP '+r.status+' - '+t.slice(0,200));const data=JSON.parse(t);if(data.ok!==true)throw new Error('Healthcheck failed: unexpected payload '+t);console.log(t)}).catch(e=>{console.error(e.message);process.exit(1)})\""
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "lovable-tagger": "^1.1.7",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.11",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.4.2"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "minimatch": "^3.1.4",
    "nanoid": "^3.3.8",
    "picomatch": "^2.3.2",
    "rollup": "^4.60.1",
    "yaml": "^2.8.3",
    "vite": {
      "esbuild": "^0.25.0"
    }
  }
}
